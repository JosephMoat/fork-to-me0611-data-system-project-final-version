MYSQL_ROOT_PASSWORD=change-this-root-password
MYSQL_DATABASE=graduation_credit
MYSQL_USER=app_user
MYSQL_PASSWORD=change-this-app-password

SECRET_KEY=change-this-to-a-long-random-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Server HTTP port for the frontend Nginx container.
FRONTEND_PORT=80

# Keep false in production. Run seed only for demo data initialization.
RUN_CREATE_TABLES=true
RUN_SEED=false
